local function fmt(n)
	if not n then return "?" end
	local s = {"","K","M","B","T","Q"}
	local i = 1
	while n >= 1000 and i < #s do n=n/1000; i=i+1 end
	return "$".. (n>=100 and string.format("%.0f",n) or n>=10 and string.format("%.1f",n) or string.format("%.2f",n)) .. s[i]
end

local function parseCash(v)
	v = tostring(v):gsub("%$", "")
	local suffixes = {K=1e3, M=1e6, B=1e9, T=1e12, Q=1e15}
	local num, suffix = v:match("^([%d%.]+)(%a?)$")
	if not num then return 0 end
	return tonumber(num) * (suffixes[suffix] or 1)
end

