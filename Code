local function switchTab(name)
	activeTab = name

	for _, page in pairs(tabPages) do page.Visible = false end

	local page = tabPages[name]
	if page then
		page.Visible = true
		-- Resize win to fit page + header + tabbar + footer
		local pageH = page.Size.Y.Offset
