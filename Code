		win.Size = UDim2.new(0, WIN_W, 0, totalH)
		footerLbl.Position = UDim2.new(0,8,0, CONTENT_Y + pageH + 4)
	end

	for tabName, btn in pairs(tabBtns) do
		if tabName == name then
			TweenService:Create(btn, tw, {BackgroundColor3=C.accent}):Play()
			TweenService:Create(btn, tw, {TextColor3=C.white}):Play()
		else
			TweenService:Create(btn, tw, {BackgroundColor3=C.raised}):Play()
			TweenService:Create(btn, tw, {TextColor3=C.sub}):Play()
		end
	end
end

