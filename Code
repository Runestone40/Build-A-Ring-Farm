-- ─── Auto Collect Logic ───────────────────────────────────────────────────────

local function getCollectPrompts()
	local prompts = {}

	for _, obj in ipairs(honeycombRoot:GetDescendants()) do
		if obj:IsA("ProximityPrompt") and obj.Name == "CollectPrompt" then
			local part = obj.Parent

			if part and part:IsA("BasePart") then
				prompts[#prompts + 1] = {prompt = obj, part = part}
			else
				local fallback = part and part:FindFirstChildWhichIsA("BasePart", true)
				if fallback then
					prompts[#prompts + 1] = {prompt = obj, part = fallback}
				end
			end
		end
	end

	return prompts
end

local function teleportToNearestCollectPrompt(player)
	local character = player.Character or player.CharacterAdded:Wait()
	local root = character:WaitForChild("HumanoidRootPart")

	local nearest, nearestDist = nil, math.huge

	for _, data in ipairs(getCollectPrompts()) do
		local dist = (root.Position - data.part.Position).Magnitude
		if dist < nearestDist then
			nearestDist = dist
			nearest = data
		end
	end

	if nearest then
		root.CFrame = nearest.part.CFrame + Vector3.new(0, 3, 0)
		task.wait(0.1)
		fireproximityprompt(nearest.prompt)
	end
end

