	autoFertEnabled=false; autoSellEnabled=false; autoEggEnabled=false; autoCollectEnabled=false
	local fadeOut=TweenInfo.new(0.2,Enum.EasingStyle.Quad)
	local function fadeDescendants(parent)
		for _,obj in ipairs(parent:GetDescendants()) do
			if obj:IsA("Frame") or obj:IsA("ScrollingFrame") then
				TweenService:Create(obj,fadeOut,{BackgroundTransparency=1}):Play()
			elseif obj:IsA("TextLabel") or obj:IsA("TextButton") then
				TweenService:Create(obj,fadeOut,{TextTransparency=1,BackgroundTransparency=1}):Play()
			elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
				TweenService:Create(obj,fadeOut,{ImageTransparency=1,BackgroundTransparency=1}):Play()
			elseif obj:IsA("UIStroke") then
				TweenService:Create(obj,fadeOut,{Transparency=1}):Play()
			end
		end
	end
	TweenService:Create(win,fadeOut,{BackgroundTransparency=1}):Play()
	TweenService:Create(seedPanel,fadeOut,{BackgroundTransparency=1}):Play()
	TweenService:Create(gearPanel,fadeOut,{BackgroundTransparency=1}):Play()
	TweenService:Create(eggPanel,fadeOut,{BackgroundTransparency=1}):Play()
	TweenService:Create(toastFrame,fadeOut,{BackgroundTransparency=1}):Play()
	fadeDescendants(win); fadeDescendants(seedPanel); fadeDescendants(gearPanel)
	fadeDescendants(eggPanel); fadeDescendants(toastFrame)
	task.delay(0.25, function() if gui and gui.Parent then gui:Destroy() end end)
end)
