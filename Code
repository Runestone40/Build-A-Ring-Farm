-- ─── Plot Finder ─────────────────────────────────────────────────────────────
-- Reliably finds the local player's owned plot in workspace.Map.Plots
-- by checking common attribute names on each plot model.

local plotsFolder = workspace:WaitForChild("Map"):WaitForChild("Plots")

local PLOT_ATTR_CANDIDATES = {
	"OwnerUserId", "UserId", "Owner", "Player", "OwnerName", "DisplayName",
}

local function getPlotOwnerValue(plot)
	for _, attrName in ipairs(PLOT_ATTR_CANDIDATES) do
		local value = plot:GetAttribute(attrName)
		if value ~= nil then return attrName, value end
	end
	return nil, nil
end

local function findPlayerPlot(targetPlayer)
	for _, plot in ipairs(plotsFolder:GetChildren()) do
		local _, value = getPlotOwnerValue(plot)
		if value then
			if typeof(value) == "number" and value == targetPlayer.UserId then
				return plot
			end
			if typeof(value) == "string" then
				if value == targetPlayer.Name or value == targetPlayer.DisplayName then
					return plot
				end
			end
		end
	end
	return nil
end

-- Cache the local player's plot (refreshed on demand)
local cachedHomePlot = nil
local function getHomePlot()
	if cachedHomePlot and cachedHomePlot.Parent then return cachedHomePlot end
	cachedHomePlot = findPlayerPlot(player)
	return cachedHomePlot
end

